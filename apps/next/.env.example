# ---------------------------------------------------------------
# Copy this file to .env (gitignored) and fill in real values.
# NEXT_PUBLIC_ vars are safe to expose to the browser.
# All others are server-only — never prefix them with NEXT_PUBLIC_.
# ---------------------------------------------------------------

# Supabase — public (anon) key, safe for browser/mobile
NEXT_PUBLIC_SUPABASE_URL=https://<project-ref>.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=<anon-key>

# Supabase — service role key, SERVER ONLY. Never expose to client.
# Rotate immediately if ever committed to source control.
SUPABASE_SERVICE_ROLE_KEY=<service-role-key>

# Upstash Redis — copy from your Upstash dashboard → "REST API" tab
UPSTASH_REDIS_REST_URL=https://<host>.upstash.io
UPSTASH_REDIS_REST_TOKEN=<your-upstash-rest-token>

# Vercel Cron secret — set this in Vercel env vars and in vercel.json
# Used to authenticate the /api/cron/* routes so only Vercel can trigger them
CRON_SECRET=<generate-a-long-random-string>
